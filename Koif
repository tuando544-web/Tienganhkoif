/* ============================================================
   KOIF – CSS  |  Gen Z · Xanh dương + Xanh lá
   ============================================================ */

:root {
  --blue:       #0ea5e9;
  --blue-dark:  #0284c7;
  --blue-light: #e0f2fe;
  --green:      #22c55e;
  --green-dark: #16a34a;
  --green-light:#dcfce7;
  --bg:         #f0fafb;
  --surface:    #ffffff;
  --surface2:   #f4fbff;
  --border:     #c7e8f5;
  --text:       #0f1f2e;
  --text2:      #4a6577;
  --text3:      #8aa8b8;
  --danger:     #ef4444;
  --warn:       #f97316;
  --radius:     16px;
  --radius-sm:  10px;
  --shadow:     0 4px 24px rgba(14,165,233,.12);
  --shadow-lg:  0 8px 40px rgba(14,165,233,.2);
  --grad:       linear-gradient(135deg, var(--blue) 0%, var(--green) 100%);
  --nav-h:      60px;
  --bnav-h:     68px;
  --font-head:  'Syne', sans-serif;
  --font-body:  'Plus Jakarta Sans', sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { font-size: 16px; -webkit-tap-highlight-color: transparent; }

body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── SPLASH ── */
.splash {
  position: fixed; inset: 0; z-index: 999;
  background: var(--grad);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 12px;
  transition: opacity .5s, transform .5s;
}
.splash.fade-out { opacity: 0; transform: scale(.95); pointer-events: none; }

.splash-logo {
  font-family: var(--font-head);
  font-size: 56px; font-weight: 800;
  color: #fff; letter-spacing: -2px;
  animation: pop .6s cubic-bezier(.34,1.56,.64,1) both;
}
.logo-k { color: #fff; }
.logo-oif { color: rgba(255,255,255,.75); }

.splash-tagline {
  color: rgba(255,255,255,.8);
  font-size: 14px; font-weight: 500; letter-spacing: 1px;
  text-transform: uppercase;
  animation: fadein .8s .3s both;
}

.splash-loader {
  display: flex; gap: 8px; margin-top: 32px;
  animation: fadein .5s .5s both;
}
.splash-loader span {
  width: 8px; height: 8px; border-radius: 50%;
  background: rgba(255,255,255,.7);
  animation: bounce 1s infinite;
}
.splash-loader span:nth-child(2) { animation-delay: .15s; }
.splash-loader span:nth-child(3) { animation-delay: .3s; }

@keyframes bounce { 0%,80%,100%{transform:translateY(0)} 40%{transform:translateY(-10px)} }
@keyframes pop { from{transform:scale(.5);opacity:0} to{transform:scale(1);opacity:1} }
@keyframes fadein { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:none} }
@keyframes slideUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:none} }

/* ── APP WRAPPER ── */
.app {
  display: flex; flex-direction: column;
  min-height: 100vh; max-width: 520px;
  margin: 0 auto; position: relative;
}

/* ── TOP NAV ── */
.topnav {
  position: sticky; top: 0; z-index: 100;
  height: var(--nav-h);
  background: rgba(255,255,255,.85);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center;
  padding: 0 16px; gap: 12px;
}

.nav-logo {
  font-family: var(--font-head);
  font-size: 26px; font-weight: 800;
  cursor: pointer; user-select: none;
  background: var(--grad);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: -1px;
  flex: 1;
}

.nav-actions { display: flex; gap: 8px; }

.icon-btn {
  width: 36px; height: 36px; border-radius: 10px;
  background: var(--blue-light); border: none;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  color: var(--blue-dark); transition: all .2s;
}
.icon-btn svg { width: 18px; height: 18px; }
.icon-btn:hover { background: var(--blue); color: #fff; transform: scale(1.05); }

/* ── SEARCH BAR ── */
.search-bar {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 16px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  animation: slideUp .2s both;
}
.search-bar input {
  flex: 1; border: none; outline: none;
  font-family: var(--font-body); font-size: 15px;
  color: var(--text); background: transparent;
}
.search-bar button {
  border: none; background: none; cursor: pointer;
  color: var(--text3); font-size: 16px;
}

/* ── MAIN CONTENT ── */
main { flex: 1; overflow-y: auto; padding-bottom: var(--bnav-h); }

/* ── SCREENS ── */
.screen { display: none; animation: slideUp .25s both; }
.screen.active { display: block; }

/* ── HOME ── */
.home-hero {
  background: var(--grad);
  padding: 24px 20px 28px;
  display: flex; align-items: flex-start;
  justify-content: space-between; gap: 12px;
}
.hero-text h1 {
  font-family: var(--font-head);
  font-size: 22px; font-weight: 700;
  color: #fff; margin-bottom: 4px;
}
.hero-text p { color: rgba(255,255,255,.8); font-size: 14px; }
.hero-stats { display: flex; gap: 8px; flex-shrink: 0; }
.stat-pill {
  background: rgba(255,255,255,.2);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,.3);
  border-radius: 20px; padding: 4px 12px;
  font-size: 13px; color: #fff; font-weight: 600;
}

.section-label {
  padding: 20px 16px 10px;
  font-size: 12px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 1.2px;
  color: var(--text3);
}

.deck-grid {
  padding: 0 12px 16px;
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.deck-card {
  border-radius: var(--radius);
  padding: 18px 16px 16px;
  cursor: pointer; position: relative; overflow: hidden;
  transition: transform .2s, box-shadow .2s;
  box-shadow: 0 2px 12px rgba(0,0,0,.08);
  min-height: 110px;
  display: flex; flex-direction: column; gap: 6px;
}
.deck-card::before {
  content: '';
  position: absolute; top: -20px; right: -20px;
  width: 80px; height: 80px; border-radius: 50%;
  background: rgba(255,255,255,.15);
}
.deck-card:hover, .deck-card:active { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
.deck-emoji { font-size: 28px; line-height: 1; }
.deck-name {
  font-family: var(--font-head); font-weight: 700;
  font-size: 15px; color: #fff; line-height: 1.2;
}
.deck-count { font-size: 12px; color: rgba(255,255,255,.75); }

/* ── EMPTY STATE ── */
.empty-state {
  text-align: center; padding: 48px 24px;
  animation: fadein .4s both;
}
.empty-icon { font-size: 48px; margin-bottom: 12px; }
.empty-state p { color: var(--text2); font-size: 15px; line-height: 1.6; margin-bottom: 20px; }

/* ── FAB ── */
.fab {
  position: fixed; bottom: calc(var(--bnav-h) + 16px); right: 20px;
  width: 56px; height: 56px; border-radius: 50%;
  background: var(--grad); border: none;
  box-shadow: 0 4px 20px rgba(14,165,233,.4);
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  color: #fff; z-index: 50;
  transition: transform .2s, box-shadow .2s;
}
.fab svg { width: 24px; height: 24px; }
.fab:hover { transform: scale(1.1); box-shadow: 0 6px 30px rgba(14,165,233,.5); }

/* ── SCREEN HEADER ── */
.screen-header {
  display: flex; align-items: center; gap: 12px;
  padding: 14px 16px 12px;
  border-bottom: 1px solid var(--border);
  position: sticky; top: 0; background: rgba(255,255,255,.9);
  backdrop-filter: blur(12px); z-index: 10;
}
.screen-header h2 {
  flex: 1;
  font-family: var(--font-head); font-weight: 700;
  font-size: 20px; color: var(--text);
}

.back-btn {
  width: 36px; height: 36px; border-radius: 10px;
  border: none; background: var(--blue-light);
  color: var(--blue-dark); font-size: 18px;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: all .2s; flex-shrink: 0;
}
.back-btn:hover { background: var(--blue); color: #fff; }

/* ── MANAGE ── */
.manage-grid {
  padding: 16px; display: grid;
  grid-template-columns: repeat(2, 1fr); gap: 12px;
}

.manage-card {
  background: var(--surface); border-radius: var(--radius);
  border: 1px solid var(--border); padding: 20px 16px;
  cursor: pointer; transition: all .2s;
  box-shadow: var(--shadow);
}
.manage-card:hover { transform: translateY(-2px); border-color: var(--blue); box-shadow: var(--shadow-lg); }
.manage-icon { font-size: 28px; margin-bottom: 10px; }
.manage-label { font-weight: 700; font-size: 14px; color: var(--text); margin-bottom: 4px; }
.manage-sub { font-size: 12px; color: var(--text3); }

/* ── BACKUP ── */
.backup-section {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 12px; padding: 16px 16px 0;
}
.backup-card {
  background: var(--surface); border-radius: var(--radius);
  border: 1px solid var(--border); padding: 20px 16px;
  display: flex; flex-direction: column; gap: 10px;
  box-shadow: var(--shadow);
}
.backup-card.sheets-sync { margin: 12px 16px; grid-column: span 1; }
.backup-icon { font-size: 32px; }
.backup-card h3 { font-family: var(--font-head); font-size: 16px; font-weight: 700; }
.backup-card p { font-size: 13px; color: var(--text2); line-height: 1.5; }

.sheets-btns { display: flex; gap: 8px; }
.hint-text { font-size: 11px; color: var(--text3); }
.hint-text a { color: var(--blue); text-decoration: none; }
.code-block {
  background: #f1f5f9; border-radius: 8px; padding: 12px;
  font-size: 11px; color: #334155; overflow-x: auto;
  line-height: 1.6; font-family: monospace;
}
.help-content p { font-size: 14px; color: var(--text2); margin-bottom: 8px; line-height: 1.6; }
.help-content code { background: var(--blue-light); color: var(--blue-dark); padding: 2px 6px; border-radius: 4px; font-size: 12px; }

/* ── FORMS ── */
.form-body { padding: 16px; display: flex; flex-direction: column; gap: 20px; }
.form-group { display: flex; flex-direction: column; gap: 8px; }
.form-group label { font-size: 13px; font-weight: 700; color: var(--text2); text-transform: uppercase; letter-spacing: .5px; }

.text-input, .select-input {
  border: 2px solid var(--border); border-radius: var(--radius-sm);
  padding: 12px 14px; font-size: 15px;
  font-family: var(--font-body); color: var(--text);
  background: var(--surface); outline: none;
  transition: border-color .2s, box-shadow .2s;
  width: 100%;
}
.text-input:focus, .select-input:focus {
  border-color: var(--blue);
  box-shadow: 0 0 0 3px rgba(14,165,233,.15);
}
.textarea { min-height: 90px; resize: vertical; }

.emoji-picker {
  display: flex; flex-wrap: wrap; gap: 8px;
}
.emoji-opt {
  width: 44px; height: 44px; border-radius: 10px;
  background: var(--surface2); border: 2px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; cursor: pointer; transition: all .15s;
}
.emoji-opt:hover, .emoji-opt.active {
  border-color: var(--blue); background: var(--blue-light);
  transform: scale(1.1);
}

.color-picker { display: flex; flex-wrap: wrap; gap: 10px; }
.color-opt {
  width: 36px; height: 36px; border-radius: 50%;
  cursor: pointer; border: 3px solid transparent;
  transition: all .15s; position: relative;
}
.color-opt.active::after {
  content: '✓'; position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-size: 14px; font-weight: 700;
}
.color-opt:hover { transform: scale(1.15); }

.deck-preview {
  background: var(--grad); border-radius: var(--radius);
  padding: 20px; display: flex; align-items: center; gap: 14px;
  transition: all .3s;
}
.deck-preview span:first-child { font-size: 32px; }
#previewName {
  font-family: var(--font-head); font-weight: 700;
  font-size: 18px; color: #fff;
}

.form-btns { display: flex; gap: 10px; }

/* ── BUTTONS ── */
.btn-primary {
  flex: 1; padding: 13px 20px; border-radius: var(--radius-sm);
  background: var(--grad); border: none; color: #fff;
  font-family: var(--font-body); font-weight: 700; font-size: 15px;
  cursor: pointer; transition: all .2s; letter-spacing: .3px;
}
.btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 20px rgba(14,165,233,.4); }

.btn-secondary {
  flex: 1; padding: 13px 20px; border-radius: var(--radius-sm);
  background: var(--surface2); border: 2px solid var(--border);
  color: var(--text); font-family: var(--font-body);
  font-weight: 700; font-size: 15px; cursor: pointer;
  transition: all .2s; text-align: center; display: block; text-decoration: none;
}
.btn-secondary:hover { border-color: var(--blue); color: var(--blue); }

.btn-danger {
  flex: 1; padding: 13px 20px; border-radius: var(--radius-sm);
  background: var(--danger); border: none; color: #fff;
  font-family: var(--font-body); font-weight: 700; font-size: 15px;
  cursor: pointer; transition: all .2s;
}
.btn-danger:hover { opacity: .9; }

/* ── MANAGE DECK LIST ── */
.manage-deck-list { padding: 12px 16px; display: flex; flex-direction: column; gap: 10px; }

.mdeck-item {
  background: var(--surface); border-radius: var(--radius);
  border: 1px solid var(--border); padding: 14px 16px;
  display: flex; align-items: center; gap: 12px;
  box-shadow: 0 2px 8px rgba(0,0,0,.05);
  animation: slideUp .2s both;
}
.mdeck-icon {
  width: 44px; height: 44px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; flex-shrink: 0;
}
.mdeck-info { flex: 1; min-width: 0; }
.mdeck-name { font-weight: 700; font-size: 15px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.mdeck-count { font-size: 12px; color: var(--text3); margin-top: 2px; }
.mdeck-actions { display: flex; gap: 6px; }
.mdeck-btn {
  width: 32px; height: 32px; border-radius: 8px; border: none;
  cursor: pointer; font-size: 14px; display: flex;
  align-items: center; justify-content: center; transition: all .15s;
}
.mdeck-btn.edit { background: var(--blue-light); color: var(--blue-dark); }
.mdeck-btn.edit:hover { background: var(--blue); color: #fff; }
.mdeck-btn.del { background: #fee2e2; color: var(--danger); }
.mdeck-btn.del:hover { background: var(--danger); color: #fff; }

/* ── CARD LIST ── */
.deck-actions {
  padding: 14px 16px; display: flex; gap: 10px;
}
.action-pill {
  padding: 10px 18px; border-radius: 20px; border: 2px solid var(--border);
  background: var(--surface); font-family: var(--font-body);
  font-size: 14px; font-weight: 600; cursor: pointer;
  transition: all .2s; color: var(--text2);
}
.action-pill.active-pill {
  background: var(--grad); border-color: transparent; color: #fff;
  box-shadow: 0 4px 16px rgba(14,165,233,.3);
}
.action-pill:hover:not(.active-pill) { border-color: var(--blue); color: var(--blue); }

.card-list-items { padding: 0 16px 16px; display: flex; flex-direction: column; gap: 8px; }

.card-item {
  background: var(--surface); border-radius: var(--radius-sm);
  border: 1px solid var(--border); padding: 14px 16px;
  display: flex; align-items: center; gap: 12px;
  animation: slideUp .15s both; cursor: pointer;
  transition: border-color .2s;
}
.card-item:hover { border-color: var(--blue); }
.card-item-body { flex: 1; min-width: 0; }
.card-front-text { font-weight: 600; font-size: 15px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.card-back-text { font-size: 13px; color: var(--text2); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.card-item-actions { display: flex; gap: 6px; flex-shrink: 0; }

/* ── STUDY ── */
.study-header { border-bottom: 1px solid var(--border); }

.study-progress-wrap {
  flex: 1; display: flex; align-items: center; gap: 10px;
}
.study-progress-bar {
  flex: 1; height: 8px; border-radius: 4px;
  background: var(--border); overflow: hidden;
}
#studyProgressFill {
  height: 100%; border-radius: 4px;
  background: var(--grad); transition: width .4s ease;
  width: 0%;
}
#studyProgressLabel { font-size: 12px; font-weight: 700; color: var(--text2); white-space: nowrap; }

.study-area {
  padding: 24px 16px;
  min-height: calc(100vh - var(--nav-h) - var(--bnav-h) - 60px);
  display: flex; flex-direction: column; align-items: center; gap: 24px;
}

.flashcard {
  width: 100%; max-width: 380px; height: 260px;
  perspective: 1000px; cursor: pointer;
}
.flashcard-inner {
  width: 100%; height: 100%;
  transform-style: preserve-3d;
  transition: transform .5s cubic-bezier(.4,0,.2,1);
  position: relative;
}
.flashcard-inner.flipped { transform: rotateY(180deg); }

.flashcard-face {
  position: absolute; inset: 0;
  border-radius: 20px;
  backface-visibility: hidden;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 28px; gap: 12px;
  box-shadow: var(--shadow-lg);
}
.flashcard-face.front {
  background: var(--surface);
  border: 2px solid var(--border);
}
.flashcard-face.back {
  background: var(--grad);
  transform: rotateY(180deg);
}

.card-lang-badge {
  position: absolute; top: 14px; right: 14px;
  background: var(--blue-light); color: var(--blue-dark);
  font-size: 11px; font-weight: 700; padding: 3px 8px;
  border-radius: 6px; text-transform: uppercase;
}
.card-content {
  font-family: var(--font-head); font-size: 24px; font-weight: 700;
  text-align: center; line-height: 1.3; color: var(--text);
}
.flashcard-face.back .card-content { color: #fff; }
.card-hint {
  font-size: 12px; color: var(--text3); position: absolute; bottom: 14px;
}
.card-note {
  font-size: 13px; color: rgba(255,255,255,.8);
  text-align: center;
}

.study-btns {
  display: flex; gap: 14px; width: 100%; max-width: 380px;
}
.study-btn {
  flex: 1; padding: 16px; border-radius: var(--radius);
  border: none; cursor: pointer; display: flex; flex-direction: column;
  align-items: center; gap: 6px; font-family: var(--font-body);
  font-size: 14px; font-weight: 700; transition: all .2s;
}
.study-btn-icon { font-size: 24px; }
.study-btn.wrong { background: #fee2e2; color: var(--danger); }
.study-btn.correct { background: var(--green-light); color: var(--green-dark); }
.study-btn:hover { transform: translateY(-2px); box-shadow: var(--shadow); }

/* ── RESULT ── */
.result-wrap {
  padding: 48px 24px;
  display: flex; flex-direction: column;
  align-items: center; gap: 16px;
  text-align: center; animation: fadein .4s both;
}
.result-emoji { font-size: 64px; animation: pop .5s cubic-bezier(.34,1.56,.64,1) both; }
.result-wrap h2 { font-family: var(--font-head); font-size: 28px; font-weight: 800; }
.result-wrap p { color: var(--text2); font-size: 15px; }
.result-stats { display: flex; gap: 16px; margin: 8px 0; }
.result-stat {
  padding: 16px 24px; border-radius: var(--radius);
  display: flex; flex-direction: column; align-items: center; gap: 4px;
}
.result-stat span { font-family: var(--font-head); font-size: 32px; font-weight: 800; }
.result-stat small { font-size: 12px; font-weight: 600; text-transform: uppercase; }
.result-stat.correct { background: var(--green-light); color: var(--green-dark); }
.result-stat.wrong { background: #fee2e2; color: var(--danger); }
.result-btns { display: flex; gap: 10px; width: 100%; }

/* ── STATS ── */
.stats-content { padding: 16px; display: flex; flex-direction: column; gap: 12px; }
.stats-deck-card {
  background: var(--surface); border-radius: var(--radius);
  border: 1px solid var(--border); padding: 16px;
  display: flex; gap: 14px; align-items: center;
  animation: slideUp .2s both;
}
.stats-deck-icon { font-size: 28px; }
.stats-info { flex: 1; }
.stats-deck-name { font-weight: 700; font-size: 15px; margin-bottom: 8px; }
.stats-bar-wrap { display: flex; align-items: center; gap: 8px; }
.stats-bar { flex: 1; height: 8px; background: var(--border); border-radius: 4px; overflow: hidden; }
.stats-bar-fill { height: 100%; background: var(--grad); border-radius: 4px; transition: width .6s; }
.stats-pct { font-size: 12px; font-weight: 700; color: var(--blue); width: 36px; text-align: right; }

/* ── BOTTOM NAV ── */
.bottomnav {
  position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);
  width: 100%; max-width: 520px;
  height: var(--bnav-h);
  background: rgba(255,255,255,.92);
  backdrop-filter: blur(16px);
  border-top: 1px solid var(--border);
  display: flex; align-items: center;
  z-index: 100;
}
.bnav-btn {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; gap: 4px;
  border: none; background: none; cursor: pointer;
  color: var(--text3); padding: 8px 0;
  transition: color .2s;
}
.bnav-btn svg { width: 22px; height: 22px; }
.bnav-btn span { font-size: 10px; font-weight: 600; }
.bnav-btn.active { color: var(--blue); }
.bnav-btn.active svg { filter: drop-shadow(0 0 4px rgba(14,165,233,.4)); }

/* ── MODAL ── */
.modal {
  position: fixed; inset: 0; z-index: 200;
  background: rgba(15,31,46,.5);
  backdrop-filter: blur(4px);
  display: flex; align-items: center; justify-content: center;
  padding: 24px; animation: fadein .2s both;
}
.modal-card {
  background: var(--surface); border-radius: 20px;
  padding: 28px 24px; width: 100%; max-width: 360px;
  box-shadow: 0 20px 60px rgba(0,0,0,.2);
  animation: pop .3s cubic-bezier(.34,1.56,.64,1) both;
  display: flex; flex-direction: column; gap: 12px;
  text-align: center;
}
.modal-card.large { max-width: 440px; text-align: left; }
.modal-emoji { font-size: 40px; }
.modal-card h3 { font-family: var(--font-head); font-size: 20px; font-weight: 700; }
.modal-card p { color: var(--text2); font-size: 14px; line-height: 1.5; }
.modal-btns { display: flex; gap: 10px; margin-top: 8px; }

/* ── TOAST ── */
.toast {
  position: fixed; bottom: calc(var(--bnav-h) + 16px);
  left: 50%; transform: translateX(-50%);
  background: #1e293b; color: #fff;
  padding: 12px 20px; border-radius: 20px;
  font-size: 14px; font-weight: 600;
  z-index: 300; white-space: nowrap;
  animation: toastin .3s both;
  box-shadow: 0 4px 20px rgba(0,0,0,.3);
}
.toast.hidden { display: none; }
@keyframes toastin { from{opacity:0;transform:translate(-50%,16px)} to{opacity:1;transform:translate(-50%,0)} }

/* ── UTILITIES ── */
.hidden { display: none !important; }

/* ── DESKTOP TWEAKS ── */
@media (min-width: 521px) {
  body { display: flex; justify-content: center; background: #dbeafe; }
  .app {
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    box-shadow: 0 0 80px rgba(14,165,233,.15);
  }
  .bottomnav, .fab { max-width: 520px; }
}

@media (prefers-color-scheme: dark) {
  /* opt-in dark mode for future */
}

// KOIF Service Worker – Offline Support
const CACHE = 'koif-v1';
const ASSETS = [
  './',
  './index.html',
  './style.css',
  './app.js',
  './manifest.json',
  'https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap'
];

self.addEventListener('install', e => {
  e.waitUntil(
    caches.open(CACHE).then(cache => cache.addAll(ASSETS)).then(() => self.skipWaiting())
  );
});

self.addEventListener('activate', e => {
  e.waitUntil(
    caches.keys().then(keys =>
      Promise.all(keys.filter(k=>k!==CACHE).map(k=>caches.delete(k)))
    ).then(()=>self.clients.claim())
  );
});

self.addEventListener('fetch', e => {
  // Network first for API calls, cache first for assets
  if (e.request.url.includes('googleapis.com') || e.request.url.includes('docs.google.com')) {
    e.respondWith(
      fetch(e.request).catch(() => caches.match(e.request))
    );
    return;
  }
  e.respondWith(
    caches.match(e.request).then(cached => cached || fetch(e.request).then(res => {
      const clone = res.clone();
      caches.open(CACHE).then(c => c.put(e.request, clone));
      return res;
    }))
  );
});
