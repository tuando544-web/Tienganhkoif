// ── INDEXEDDB SETUP ────────────────────────────────────────
const DB_NAME    = 'koif_db';
const DB_VERSION = 1;
let db = null;

function openDB() {
  return new Promise((resolve, reject) => {
    const req = indexedDB.open(DB_NAME, DB_VERSION);
    req.onupgradeneeded = e => {
      const d = e.target.result;
      if (!d.objectStoreNames.contains('decks')) {
        d.createObjectStore('decks', { keyPath: 'id' });
      }
      if (!d.objectStoreNames.contains('stats')) {
        d.createObjectStore('stats', { keyPath: 'deckId' });
      }
      if (!d.objectStoreNames.contains('session')) {
        d.createObjectStore('session', { keyPath: 'key' });
      }
    };
    req.onsuccess = e => { db = e.target.result; resolve(db); };
    req.onerror   = e => reject(e.target.error);
  });
}

function tx(storeName, mode='readonly') {
  return db.transaction(storeName, mode).objectStore(storeName);
}
function dbGetAll(store) {
  return new Promise((res,rej)=>{ const r=tx(store).getAll(); r.onsuccess=e=>res(e.target.result); r.onerror=e=>rej(e.target.error); });
}
function dbGet(store, key) {
  return new Promise((res,rej)=>{ const r=tx(store).get(key); r.onsuccess=e=>res(e.target.result); r.onerror=e=>rej(e.target.error); });
}
function dbPut(store, value) {
  return new Promise((res,rej)=>{ const r=tx(store,'readwrite').put(value); r.onsuccess=e=>res(e.target.result); r.onerror=e=>rej(e.target.error); });
}
function dbDelete(store, key) {
  return new Promise((res,rej)=>{ const r=tx(store,'readwrite').delete(key); r.onsuccess=e=>res(); r.onerror=e=>rej(e.target.error); });
}
function dbClear(store) {
  return new Promise((res,rej)=>{ const r=tx(store,'readwrite').clear(); r.onsuccess=()=>res(); r.onerror=e=>rej(e.target.error); });
}

// ── STATE ──────────────────────────────────────────────────
let state = { decks:[], stats:{}, activeDeckId:null, session:null };

async function loadAll() {
  const [decks, statsArr] = await Promise.all([dbGetAll('decks'), dbGetAll('stats')]);
  state.decks = decks || [];
  state.stats = {};
  (statsArr||[]).forEach(s=>{ state.stats[s.deckId]=s; });
}
async function saveDeckToDB(deck)      { await dbPut('decks', deck); }
async function deleteDeckFromDB(id)    { await dbDelete('decks', id); }
async function saveStatToDB(deckId)    { const s=state.stats[deckId]; if(s) await dbPut('stats',{...s,deckId}); }
async function saveSession()           { if(state.session) await dbPut('session',{key:'current',...state.session}); else await dbDelete('session','current').catch(()=>{}); }
async function loadSessionFromDB()     { return await dbGet('session','current')||null; }

// ── HELPERS ────────────────────────────────────────────────
function uid()         { return Date.now().toString(36)+Math.random().toString(36).slice(2,7); }
function getDeck(id)   { return state.decks.find(d=>d.id===id); }
function shuffle(arr)  { const a=[...arr]; for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];} return a; }
function adjustColor(hex,amt) {
  const n=parseInt(hex.replace('#',''),16);
  const r=Math.max(0,Math.min(255,(n>>16)+amt));
  const g=Math.max(0,Math.min(255,((n>>8)&0xff)+amt));
  const b=Math.max(0,Math.min(255,(n&0xff)+amt));
  return `#${((r<<16)|(g<<8)|b).toString(16).padStart(6,'0')}`;
}
function langLabel(code) {
  return {en:'EN',ja:'JA',ko:'KO',zh:'ZH',fr:'FR',es:'ES',other:'??'}[code]||'EN';
}
function showToast(msg,dur=2200) {
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.remove('hidden');
  clearTimeout(t._timer); t._timer=setTimeout(()=>t.classList.add('hidden'),dur);
}

// ── SCREEN ROUTER ──────────────────────────────────────────
let currentScreen='screenHome';
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  currentScreen=id;
  document.querySelectorAll('.bnav-btn').forEach(b=>b.classList.toggle('active',b.dataset.screen===id));
  document.getElementById('fabAdd').style.display=id==='screenHome'?'flex':'none';
  if(id==='screenHome')    renderHome();
  if(id==='screenDeckList') renderDeckList();
  if(id==='screenStats')   renderStats();
}

// ── HOME ───────────────────────────────────────────────────
function renderHome() {
  const grid=document.getElementById('deckGrid');
  const empty=document.getElementById('emptyState');
  document.getElementById('statDecks').textContent=state.decks.length;
  document.getElementById('statCards').textContent=state.decks.reduce((a,d)=>a+d.cards.length,0);
  grid.innerHTML='';
  if(!state.decks.length){ grid.style.display='none'; empty.classList.remove('hidden'); return; }
  grid.style.display='grid'; empty.classList.add('hidden');
  state.decks.forEach(deck=>{
    const card=document.createElement('div');
    card.className='deck-card';
    card.style.background=`linear-gradient(135deg,${deck.color} 0%,${adjustColor(deck.color,-20)} 100%)`;
    card.innerHTML=`<div class="deck-emoji">${deck.emoji}</div><div class="deck-name">${deck.name}</div><div class="deck-count">${deck.cards.length} từ</div>`;
    card.addEventListener('click',()=>openDeck(deck.id));
    grid.appendChild(card);
  });
}

// ── CARD LIST ──────────────────────────────────────────────
function openDeck(deckId) {
  state.activeDeckId=deckId;
  const deck=getDeck(deckId);
  document.getElementById('cardListTitle').textContent=`${deck.emoji} ${deck.name}`;
  renderCardList(); showScreen('screenCardList');
}
function renderCardList() {
  const deck=getDeck(state.activeDeckId);
  const list=document.getElementById('cardListItems');
  const empty=document.getElementById('emptyCards');
  list.innerHTML='';
  if(!deck||!deck.cards.length){ empty.classList.remove('hidden'); return; }
  empty.classList.add('hidden');
  deck.cards.forEach((card,idx)=>{
    const item=document.createElement('div');
    item.className='card-item';
    item.innerHTML=`<div class="card-item-body"><div class="card-front-text">${card.front}</div><div class="card-back-text">${card.back}</div></div><div class="card-item-actions"><button class="mdeck-btn edit">✏️</button><button class="mdeck-btn del">🗑️</button></div>`;
    item.querySelector('.edit').addEventListener('click',e=>{e.stopPropagation();openCardForm(idx);});
    item.querySelector('.del').addEventListener('click',e=>{e.stopPropagation();deleteCard(idx);});
    list.appendChild(item);
  });
}

// ── CARD FORM ──────────────────────────────────────────────
let editingCardIdx=null;
function openCardForm(idx=null) {
  editingCardIdx=idx;
  document.getElementById('cardFormTitle').textContent=idx===null?'Thêm từ vựng':'Chỉnh sửa từ';
  if(idx!==null){ const c=getDeck(state.activeDeckId).cards[idx]; document.getElementById('cardFront').value=c.front; document.getElementById('cardBack').value=c.back; document.getElementById('cardNote').value=c.note||''; document.getElementById('cardLang').value=c.lang||'en'; }
  else { document.getElementById('cardFront').value=''; document.getElementById('cardBack').value=''; document.getElementById('cardNote').value=''; document.getElementById('cardLang').value='en'; }
  showScreen('screenCardForm');
}
async function saveCard() {
  const front=document.getElementById('cardFront').value.trim();
  const back=document.getElementById('cardBack').value.trim();
  const note=document.getElementById('cardNote').value.trim();
  const lang=document.getElementById('cardLang').value;
  if(!front||!back){ showToast('⚠️ Vui lòng điền đủ mặt trước và sau!'); return; }
  const deck=getDeck(state.activeDeckId);
  const card={id:uid(),front,back,note,lang};
  if(editingCardIdx!==null){ card.id=deck.cards[editingCardIdx].id; deck.cards[editingCardIdx]=card; showToast('✅ Đã cập nhật từ vựng!'); }
  else { deck.cards.push(card); showToast('✅ Đã thêm từ vựng!'); }
  await saveDeckToDB(deck); renderCardList(); showScreen('screenCardList');
}
function deleteCard(idx) {
  showConfirm('Xóa từ vựng?','Từ này sẽ bị xóa vĩnh viễn.',async()=>{
    const deck=getDeck(state.activeDeckId); deck.cards.splice(idx,1);
    await saveDeckToDB(deck); renderCardList(); showToast('🗑️ Đã xóa từ vựng');
  });
}

// ── DECK FORM ──────────────────────────────────────────────
let editingDeckId=null, selectedEmoji='📚', selectedColor='#0ea5e9';
function openDeckForm(deckId=null) {
  editingDeckId=deckId;
  document.getElementById('deckFormTitle').textContent=deckId?'Chỉnh sửa bộ thẻ':'Tạo bộ thẻ mới';
  if(deckId){ const d=getDeck(deckId); document.getElementById('deckName').value=d.name; document.getElementById('deckDesc').value=d.desc||''; selectedEmoji=d.emoji; selectedColor=d.color; }
  else { document.getElementById('deckName').value=''; document.getElementById('deckDesc').value=''; selectedEmoji='📚'; selectedColor='#0ea5e9'; }
  document.querySelectorAll('.emoji-opt').forEach(el=>el.classList.toggle('active',el.dataset.emoji===selectedEmoji));
  document.querySelectorAll('.color-opt').forEach(el=>el.classList.toggle('active',el.dataset.color===selectedColor));
  updateDeckPreview(); showScreen('screenDeckForm');
}
function updateDeckPreview() {
  const name=document.getElementById('deckName').value||'Tên bộ thẻ';
  document.getElementById('previewEmoji').textContent=selectedEmoji;
  document.getElementById('previewName').textContent=name;
  document.getElementById('deckPreview').style.background=`linear-gradient(135deg,${selectedColor} 0%,${adjustColor(selectedColor,-20)} 100%)`;
}
async function saveDeck() {
  const name=document.getElementById('deckName').value.trim();
  const desc=document.getElementById('deckDesc').value.trim();
  if(!name){ showToast('⚠️ Vui lòng nhập tên bộ thẻ!'); return; }
  if(editingDeckId){ const d=getDeck(editingDeckId); d.name=name;d.emoji=selectedEmoji;d.color=selectedColor;d.desc=desc; await saveDeckToDB(d); showToast('✅ Đã cập nhật bộ thẻ!'); }
  else { const nd={id:uid(),name,emoji:selectedEmoji,color:selectedColor,desc,cards:[]}; state.decks.push(nd); await saveDeckToDB(nd); showToast('✅ Đã tạo bộ thẻ mới!'); }
  renderHome(); renderDeckList(); showScreen('screenDeckList');
}

// ── MANAGE DECK LIST ───────────────────────────────────────
function renderDeckList() {
  const list=document.getElementById('manageDeckList');
  list.innerHTML='';
  if(!state.decks.length){ list.innerHTML='<div class="empty-state"><div class="empty-icon">🗂️</div><p>Chưa có bộ thẻ nào</p></div>'; return; }
  state.decks.forEach(deck=>{
    const item=document.createElement('div'); item.className='mdeck-item';
    item.innerHTML=`<div class="mdeck-icon" style="background:${deck.color}22">${deck.emoji}</div><div class="mdeck-info"><div class="mdeck-name">${deck.name}</div><div class="mdeck-count">${deck.cards.length} từ vựng</div></div><div class="mdeck-actions"><button class="mdeck-btn edit">✏️</button><button class="mdeck-btn del">🗑️</button></div>`;
    item.querySelector('.edit').addEventListener('click',()=>openDeckForm(deck.id));
    item.querySelector('.del').addEventListener('click',()=>{
      showConfirm('Xóa bộ thẻ?',`Bộ thẻ "${deck.name}" và ${deck.cards.length} từ sẽ bị xóa.`,async()=>{
        state.decks=state.decks.filter(d=>d.id!==deck.id);
        await deleteDeckFromDB(deck.id); renderDeckList(); renderHome(); showToast('🗑️ Đã xóa bộ thẻ');
      });
    });
    list.appendChild(item);
  });
}

// ── STUDY ──────────────────────────────────────────────────
let isFlipped=false;
async function startStudy(resume=false) {
  const deck=getDeck(state.activeDeckId);
  if(!deck.cards.length){ showToast('⚠️ Bộ thẻ chưa có từ vựng!'); return; }
  if(!resume){ state.session={deckId:state.activeDeckId,index:0,correct:0,wrong:0,shuffled:shuffle(deck.cards)}; }
  await saveSession(); isFlipped=false; showScreen('screenStudy'); renderStudyCard();
}
function renderStudyCard() {
  const sess=state.session; const total=sess.shuffled.length;
  document.getElementById('studyProgressFill').style.width=(total?(sess.index/total*100):0)+'%';
  document.getElementById('studyProgressLabel').textContent=`${sess.index} / ${total}`;
  if(sess.index>=total){ finishStudy(); return; }
  const card=sess.shuffled[sess.index];
  document.getElementById('cardFrontContent').textContent=card.front;
  document.getElementById('cardBackContent').textContent=card.back;
  document.getElementById('cardNoteContent').textContent=card.note||'';
  document.getElementById('cardLangBadge').textContent=langLabel(card.lang);
  isFlipped=false;
  document.getElementById('flashcardInner').classList.remove('flipped');
  document.getElementById('studyBtns').classList.add('hidden');
}
function flipCard() {
  if(isFlipped) return; isFlipped=true;
  document.getElementById('flashcardInner').classList.add('flipped');
  document.getElementById('studyBtns').classList.remove('hidden');
}
async function answerCard(correct) {
  if(!isFlipped) return;
  if(correct) state.session.correct++; else state.session.wrong++;
  state.session.index++; await saveSession(); renderStudyCard();
}
async function finishStudy() {
  const sess=state.session; const total=sess.shuffled.length;
  const pct=Math.round(sess.correct/total*100);
  if(!state.stats[sess.deckId]) state.stats[sess.deckId]={correct:0,wrong:0,sessions:0};
  state.stats[sess.deckId].correct+=sess.correct;
  state.stats[sess.deckId].wrong+=sess.wrong;
  state.stats[sess.deckId].sessions+=1;
  state.stats[sess.deckId].lastStudied=Date.now();
  await saveStatToDB(sess.deckId);
  state.session=null; await saveSession();
  const emoji=pct===100?'🏆':pct>=70?'🎉':pct>=40?'💪':'📖';
  const msg=pct===100?'Tuyệt vời! Bạn nhớ hết tất cả!':pct>=70?'Rất tốt! Luyện tập thêm nhé!':pct>=40?'Không tệ! Cố gắng hơn nhé!':'Hãy ôn lại và thử lại!';
  document.getElementById('resultEmoji').textContent=emoji;
  document.getElementById('resultTitle').textContent=pct===100?'Hoàn hảo!':'Hoàn thành!';
  document.getElementById('resultMsg').textContent=msg;
  document.getElementById('resultCorrect').textContent=sess.correct;
  document.getElementById('resultWrong').textContent=sess.wrong;
  showScreen('screenResult');
}

// ── STATS ──────────────────────────────────────────────────
function renderStats() {
  const cont=document.getElementById('statsContent'); cont.innerHTML='';
  if(!state.decks.length){ cont.innerHTML='<div class="empty-state"><div class="empty-icon">📈</div><p>Chưa có dữ liệu thống kê</p></div>'; return; }
  state.decks.forEach(deck=>{
    const st=state.stats[deck.id]||{correct:0,wrong:0,sessions:0};
    const total=st.correct+st.wrong; const pct=total?Math.round(st.correct/total*100):0;
    const card=document.createElement('div'); card.className='stats-deck-card';
    card.innerHTML=`<div class="stats-deck-icon">${deck.emoji}</div><div class="stats-info"><div class="stats-deck-name">${deck.name}</div><div class="stats-bar-wrap"><div class="stats-bar"><div class="stats-bar-fill" style="width:${pct}%"></div></div><div class="stats-pct">${pct}%</div></div><div style="font-size:12px;color:var(--text3);margin-top:4px">✅ ${st.correct} đúng · ❌ ${st.wrong} sai · 🔄 ${st.sessions} lần học</div></div>`;
    cont.appendChild(card);
  });
}

// ── BACKUP ────────────────────────────────────────────────
async function exportBackup() {
  const data={version:2,engine:'IndexedDB',exported:new Date().toISOString(),decks:state.decks,stats:state.stats};
  const blob=new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a'); a.href=url;
  a.download=`koif-backup-${new Date().toISOString().slice(0,10)}.json`;
  a.click(); URL.revokeObjectURL(url);
  showToast('📤 Đã xuất file backup!');
}
function importBackup(file) {
  const reader=new FileReader();
  reader.onload=async e=>{
    try {
      const data=JSON.parse(e.target.result);
      if(!data.decks) throw new Error('Invalid');
      showConfirm('Nhập dữ liệu?','Dữ liệu hiện tại sẽ bị ghi đè. Tiếp tục?',async()=>{
        await dbClear('decks'); await dbClear('stats');
        state.decks=data.decks||[]; state.stats=data.stats||{};
        for(const d of state.decks) await saveDeckToDB(d);
        for(const id of Object.keys(state.stats)) await saveStatToDB(id);
        renderHome(); showToast(`📥 Nhập thành công ${state.decks.length} bộ thẻ!`); showScreen('screenHome');
      },'Nhập');
    } catch(err){ showToast('❌ File không hợp lệ!'); }
  };
  reader.readAsText(file);
}

// ── GOOGLE SHEETS IMPORT ───────────────────────────────────
async function importFromSheets() {
  const url=document.getElementById('sheetsUrl').value.trim();
  if(!url){ showToast('⚠️ Nhập URL Google Sheet trước!'); return; }
  let csvUrl=url;
  const match=url.match(/\/spreadsheets\/d\/([a-zA-Z0-9-_]+)/);
  if(match) csvUrl=`https://docs.google.com/spreadsheets/d/${match[1]}/export?format=csv`;
  showToast('⏳ Đang tải dữ liệu...', 4000);
  try {
    const res=await fetch(csvUrl); if(!res.ok) throw new Error();
    const text=await res.text();
    const rows=text.trim().split('\n').map(r=>r.split(',').map(c=>c.replace(/^"|"$/g,'').trim()));
    const h=rows[0].map(x=>x.toLowerCase());
    const hi={deck:h.indexOf('deckname')===-1?0:h.indexOf('deckname'),front:h.indexOf('front')===-1?1:h.indexOf('front'),back:h.indexOf('back')===-1?2:h.indexOf('back'),note:h.indexOf('note')===-1?3:h.indexOf('note'),lang:h.indexOf('lang')===-1?4:h.indexOf('lang')};
    let imported=0; const updated=new Set();
    rows.slice(1).forEach(row=>{
      if(!row[hi.front]) return;
      const dname=row[hi.deck]||'Sheets Import';
      let deck=state.decks.find(d=>d.name===dname);
      if(!deck){ deck={id:uid(),name:dname,emoji:'📊',color:'#0ea5e9',desc:'Nhập từ Google Sheets',cards:[]}; state.decks.push(deck); }
      deck.cards.push({id:uid(),front:row[hi.front]||'',back:row[hi.back]||'',note:row[hi.note]||'',lang:row[hi.lang]||'en'});
      updated.add(deck); imported++;
    });
    for(const d of updated) await saveDeckToDB(d);
    renderHome(); showToast(`✅ Nhập ${imported} từ từ Google Sheets!`);
  } catch(err){ showToast('❌ Lỗi kết nối. Kiểm tra URL hoặc mạng.'); }
}

// ── CONFIRM ───────────────────────────────────────────────
let confirmCb=null;
function showConfirm(title,msg,cb,okText='Xóa') {
  document.getElementById('confirmTitle').textContent=title;
  document.getElementById('confirmMsg').textContent=msg;
  document.getElementById('confirmOk').textContent=okText;
  confirmCb=cb;
  document.getElementById('confirmModal').classList.remove('hidden');
}

// ── SEARCH ────────────────────────────────────────────────
function doSearch(q) {
  q=q.toLowerCase().trim();
  if(!q){ renderHome(); return; }
  const grid=document.getElementById('deckGrid'); const empty=document.getElementById('emptyState');
  grid.innerHTML='';
  const results=state.decks.filter(d=>d.name.toLowerCase().includes(q)||d.cards.some(c=>c.front.toLowerCase().includes(q)||c.back.toLowerCase().includes(q)));
  if(!results.length){ grid.style.display='none'; empty.classList.remove('hidden'); empty.querySelector('p').textContent=`Không tìm thấy "${q}"`; return; }
  grid.style.display='grid'; empty.classList.add('hidden');
  results.forEach(deck=>{ const card=document.createElement('div'); card.className='deck-card'; card.style.background=`linear-gradient(135deg,${deck.color} 0%,${adjustColor(deck.color,-20)} 100%)`; card.innerHTML=`<div class="deck-emoji">${deck.emoji}</div><div class="deck-name">${deck.name}</div><div class="deck-count">${deck.cards.length} từ</div>`; card.addEventListener('click',()=>openDeck(deck.id)); grid.appendChild(card); });
}

// ── RESUME ────────────────────────────────────────────────
async function checkResume() {
  const sess=await loadSessionFromDB(); if(!sess) return;
  state.session=sess;
  const deck=getDeck(sess.deckId); if(!deck){ state.session=null; await saveSession(); return; }
  document.getElementById('resumeDeckName').textContent=`${deck.emoji} ${deck.name}`;
  document.getElementById('resumeModal').classList.remove('hidden');
}

// ── STORAGE ESTIMATE ──────────────────────────────────────
async function checkDBUsage() {
  if(!navigator.storage?.estimate) return;
  const {usage,quota}=await navigator.storage.estimate();
  console.log(`💾 KOIF: ${(usage/1024/1024).toFixed(2)} MB / ${(quota/1024/1024).toFixed(0)} MB`);
}

// ── INIT ──────────────────────────────────────────────────
async function init() {
  try { await openDB(); await loadAll(); await checkResume(); checkDBUsage(); }
  catch(e){ console.error('DB error:',e); showToast('⚠️ Lỗi khởi động!'); }
  bindEvents();
  setTimeout(()=>{
    document.getElementById('splash').classList.add('fade-out');
    setTimeout(()=>{ document.getElementById('splash').style.display='none'; document.getElementById('app').classList.remove('hidden'); showScreen('screenHome'); },500);
  },1600);
}

// ── EVENTS ────────────────────────────────────────────────
function bindEvents() {
  document.getElementById('navLogo').addEventListener('click',()=>showScreen('screenHome'));
  document.getElementById('fabAdd').addEventListener('click',()=>openDeckForm());
  document.getElementById('btnCreateFirst')?.addEventListener('click',()=>openDeckForm());

  document.querySelectorAll('.bnav-btn').forEach(btn=>{
    btn.addEventListener('click',()=>{ const t=btn.dataset.screen; if(t==='screenDeckList') renderDeckList(); showScreen(t); });
  });
  document.querySelectorAll('.back-btn').forEach(btn=>btn.addEventListener('click',()=>showScreen(btn.dataset.target)));

  document.getElementById('btnManage').addEventListener('click',()=>showScreen('screenManage'));
  document.getElementById('mCardBackup').addEventListener('click',()=>showScreen('screenBackup'));
  document.getElementById('mCardDecks').addEventListener('click',()=>{ renderDeckList(); showScreen('screenDeckList'); });
  document.getElementById('mCardSheets').addEventListener('click',()=>showScreen('screenBackup'));
  document.getElementById('mCardStats').addEventListener('click',()=>{ renderStats(); showScreen('screenStats'); });

  document.getElementById('btnNewDeck').addEventListener('click',()=>openDeckForm());
  document.getElementById('btnSaveDeck').addEventListener('click',saveDeck);
  document.getElementById('btnCancelDeck').addEventListener('click',()=>showScreen('screenDeckList'));
  document.getElementById('deckName').addEventListener('input',updateDeckPreview);
  document.querySelectorAll('.emoji-opt').forEach(el=>el.addEventListener('click',()=>{ document.querySelectorAll('.emoji-opt').forEach(e=>e.classList.remove('active')); el.classList.add('active'); selectedEmoji=el.dataset.emoji; updateDeckPreview(); }));
  document.querySelectorAll('.color-opt').forEach(el=>el.addEventListener('click',()=>{ document.querySelectorAll('.color-opt').forEach(e=>e.classList.remove('active')); el.classList.add('active'); selectedColor=el.dataset.color; updateDeckPreview(); }));

  document.getElementById('btnAddCard').addEventListener('click',()=>openCardForm());
  document.getElementById('btnAddFirstCard')?.addEventListener('click',()=>openCardForm());
  document.getElementById('btnSaveCard').addEventListener('click',saveCard);
  document.getElementById('btnCancelCard').addEventListener('click',()=>showScreen('screenCardList'));

  document.getElementById('btnStartStudy').addEventListener('click',()=>startStudy(false));
  document.getElementById('flashcard').addEventListener('click',flipCard);
  document.getElementById('btnCorrect').addEventListener('click',()=>answerCard(true));
  document.getElementById('btnWrong').addEventListener('click',()=>answerCard(false));
  document.getElementById('btnExitStudy').addEventListener('click',async()=>{ await saveSession(); showScreen('screenCardList'); });
  document.getElementById('btnStudyAgain').addEventListener('click',()=>startStudy(false));
  document.getElementById('btnBackToCards').addEventListener('click',()=>showScreen('screenCardList'));
  document.getElementById('btnDeckSettings').addEventListener('click',()=>openDeckForm(state.activeDeckId));

  document.getElementById('btnExport').addEventListener('click',exportBackup);
  document.getElementById('importFile').addEventListener('change',e=>{ if(e.target.files[0]) importBackup(e.target.files[0]); e.target.value=''; });
  document.getElementById('btnSheetsImport').addEventListener('click',importFromSheets);
  document.getElementById('btnSheetsExport').addEventListener('click',()=>document.getElementById('sheetsHelpModal').classList.remove('hidden'));
  document.getElementById('sheetsHelp').addEventListener('click',e=>{ e.preventDefault(); document.getElementById('sheetsHelpModal').classList.remove('hidden'); });
  document.getElementById('closeHelpModal').addEventListener('click',()=>document.getElementById('sheetsHelpModal').classList.add('hidden'));
  document.getElementById('sheetsHelpModal').addEventListener('click',e=>{ if(e.target===e.currentTarget) e.currentTarget.classList.add('hidden'); });

  document.getElementById('btnSearch').addEventListener('click',()=>{ document.getElementById('searchBar').classList.remove('hidden'); document.getElementById('searchInput').focus(); showScreen('screenHome'); });
  document.getElementById('btnCloseSearch').addEventListener('click',()=>{ document.getElementById('searchBar').classList.add('hidden'); document.getElementById('searchInput').value=''; renderHome(); });
  document.getElementById('searchInput').addEventListener('input',e=>doSearch(e.target.value));

  document.getElementById('confirmOk').addEventListener('click',()=>{ document.getElementById('confirmModal').classList.add('hidden'); if(confirmCb){confirmCb();confirmCb=null;} });
  document.getElementById('confirmCancel').addEventListener('click',()=>{ document.getElementById('confirmModal').classList.add('hidden'); confirmCb=null; });
  document.getElementById('confirmModal').addEventListener('click',e=>{ if(e.target===e.currentTarget) e.currentTarget.classList.add('hidden'); });

  document.getElementById('btnContinue').addEventListener('click',()=>{ document.getElementById('resumeModal').classList.add('hidden'); state.activeDeckId=state.session.deckId; startStudy(true); });
  document.getElementById('btnRestart').addEventListener('click',async()=>{ document.getElementById('resumeModal').classList.add('hidden'); state.session=null; await saveSession(); });

  document.addEventListener('keydown',e=>{ if(currentScreen==='screenStudy'){ if(e.key===' '||e.key==='Enter'){e.preventDefault();flipCard();} if(e.key==='ArrowRight'||e.key==='1') answerCard(true); if(e.key==='ArrowLeft'||e.key==='2') answerCard(false); } });

  let tx=0,ty=0;
  const fc=document.getElementById('flashcard');
  fc.addEventListener('touchstart',e=>{tx=e.touches[0].clientX;ty=e.touches[0].clientY;});
  fc.addEventListener('touchend',e=>{ const dx=e.changedTouches[0].clientX-tx; const dy=e.changedTouches[0].clientY-ty; if(Math.abs(dx)>60&&Math.abs(dy)<60&&isFlipped){if(dx>0)answerCard(true);else answerCard(false);}else if(Math.abs(dx)<30&&Math.abs(dy)<30)flipCard(); });
}

document.addEventListener('DOMContentLoaded',init);

